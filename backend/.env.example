# Points at the qoldau-db service. User/password/db MUST match the POSTGRES_*
# values in the root .env.
DATABASE_URL=postgresql://qoldau:change-me-to-a-strong-password@qoldau-db:5432/qoldau

# REQUIRED. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# The app refuses to start with a placeholder or short value.
JWT_SECRET_KEY=

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
UPLOAD_DIR=uploads
RATE_LIMIT_ENABLED=true

CORS_ORIGINS=
